# Backend -> Superset
# Se Superset gira sulla STESSA macchina (fuori dai container) usa host.docker.internal:
#   il container non risolve "localhost" verso l'host.
# Se Superset gira in un altro container sulla stessa rete docker, usa il nome del servizio.
# Se Superset gira su un'altra macchina, metti IP/dominio raggiungibile.
SUPERSET_URL=http://host.docker.internal:8088
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
EMBED_TRINO_SERVER=server_x
EMBED_USER_DB=4cosite_000415_it

# Frontend (baked nel build Next.js tramite build args)
# NEXT_PUBLIC_API_URL deve essere l'URL del backend raggiungibile DAL BROWSER dell'utente,
# non da dentro al container. In locale: http://localhost:5000/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SUPERSET_URL=http://localhost:8088
NEXT_PUBLIC_USER_ID=4cosite_000415_it
