# Porta su cui gira il backend
PORT=5000

# Istanza Apache Superset di destinazione
SUPERSET_URL=http://localhost:8088
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# Default per l'utente "guest" usato nell'embedding (contesto multi-tenant Trino).
# Lo username del guest token viene costruito come `${EMBED_TRINO_SERVER}|${EMBED_USER_DB}`.
EMBED_TRINO_SERVER=server_x
EMBED_USER_DB=4cosite_000415_it
